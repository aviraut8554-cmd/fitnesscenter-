# Supabase — public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — server only. NEVER expose to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Error monitoring (optional)
SENTRY_DSN=

# --- Local development (Supabase CLI `supabase start`) ---
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Use the anon/service_role keys printed by `supabase status`.
