# Supabase — public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — server only. NEVER expose to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Error monitoring (optional)
SENTRY_DSN=

# Razorpay (Phase 2 — payments). Server-only; never expose the secret/webhook
# secret to the client. Optional at boot; the payment routes return a clear 500
# until all three are set. Use TEST keys in dev.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Encryption key for per-tenant provider secrets stored at rest (AES-256-GCM).
# 32 bytes, hex or base64. Generate one with: openssl rand -hex 32
# Required for tenant Razorpay and Resend connections.
SETTINGS_ENCRYPTION_KEY=

# Automation delivery fallback. Tenants can connect their own Resend account
# from Admin → Automations; these values provide an optional deployment-wide
# sender when no tenant connection exists.
RESEND_API_KEY=
EMAIL_FROM=

# WhatsApp delivery (Meta Cloud API; not yet self-service in the dashboard).
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Protects /api/cron/reminders. Vercel Cron sends this as a Bearer token.
CRON_SECRET=

# --- Local development (Supabase CLI `supabase start`) ---
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Use the anon/service_role keys printed by `supabase status`.
